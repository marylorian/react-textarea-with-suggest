{
  "name": "react-textarea-with-suggest",
  "version": "2.5.0",
  "description": "Textarea with suggest for React app",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "dependencies": {
    "react-textarea-autosize": "^8.5.3"
  },
  "files": [
    "lib",
    "example"
  ],
  "scripts": {
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "build:debug": "npm install && npm run build && rm -rf node_modules",
    "build": "rollup -c",
    "start": "rollup -c -w",
    "deploy:demo": "cd ./example && rm -rf node_modules && rm package-lock.json && npm i && npm run deploy && cd ../",
    "release": "node scripts/release.mjs",
    "release:dry-run": "node scripts/release.mjs --dry-run --allow-any-commits",
    "release:ci": "node scripts/release.mjs --yes --push --publish --provenance --allow-any-commits",
    "test": "jest --coverage --",
    "pre-commit": "npm run prettier:check",
    "pre-push": "npm run test",
    "prepare": "husky install"
  },
  "license": "MIT",
  "eslintConfig": {
    "extends": "react-app"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marylorian/react-textarea-with-suggest.git"
  },
  "keywords": [
    "textarea",
    "suggest",
    "textarea-suggest",
    "react",
    "react-component"
  ],
  "author": "Mariia Lobareva",
  "bugs": {
    "url": "https://github.com/marylorian/react-textarea-with-suggest/issues"
  },
  "homepage": "https://marylorian.github.io/react-textarea-with-suggest/",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "babel": {
    "presets": [
      "@babel/preset-env",
      "@babel/preset-react",
      "@babel/preset-typescript"
    ],
    "plugins": [
      "@babel/plugin-proposal-class-properties"
    ]
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.2.0",
    "react-dom": "^17.0.0 || ^18.2.0"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "devDependencies": {
    "@babel/cli": "^7.5.5",
    "@babel/core": "^7.0.0-0",
    "@babel/plugin-proposal-class-properties": "^7.5.5",
    "@babel/preset-env": "^7.5.5",
    "@babel/preset-react": "^7.0.0",
    "@babel/preset-typescript": "^7.18.6",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@types/react": "^18.0.26",
    "babel-loader": "^8.0.6",
    "css-loader": "^6.7.3",
    "husky": "^8.0.0",
    "jest": "^29.3.1",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "2.7.1",
    "rollup": "^4.60.4",
    "tslib": "^2.8.1",
    "typescript": "^4.9.4"
  }
}
